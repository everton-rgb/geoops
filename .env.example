# ============================================================================
# GeoópS — Variáveis de ambiente (configurar no Vercel: Settings → Environment Variables)
# ============================================================================
# Este arquivo é um MODELO. Nunca commitar valores reais.
# Após alterar variáveis no Vercel, faça um REDEPLOY (elas só valem em build novo).

# ===== SUPABASE — banco de dados + autenticação =====
# Painel do Supabase → Settings → API
# As VITE_* vão para o NAVEGADOR (são públicas por natureza; a segurança vem do RLS).
VITE_SUPABASE_URL=https://SEU-PROJETO.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# Mesmos valores, usados pelas funções serverless (/api):
SUPABASE_URL=https://SEU-PROJETO.supabase.co
SUPABASE_ANON_KEY=sb_publishable_...

# ⚠️ SECRETA — privilégio de administrador. NUNCA expor no navegador.
# Usada só por /api/convidar-usuario (convite de usuários por e-mail).
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...

# ===== ANTHROPIC — IA (HTTP) =====
# console.anthropic.com → API Keys. Usada só por /api/analisar (proxy seguro; a chave
# nunca chega ao navegador). O endpoint responde por STREAMING (obrigatório p/ leituras longas).
ANTHROPIC_API_KEY=sk-ant-...

# ===== E-MAIL (violação de diretrizes → diretores) =====
# Escolha UMA das vias. Se as duas existirem, o SMTP tem prioridade.

# --- VIA 1: SMTP próprio (servidor de e-mail da empresa, Gmail, Office365…) ---
SMTP_HOST=smtp.seudominio.com.br
SMTP_PORT=587
SMTP_USER=alertas@geoops.ia.br
SMTP_PASS=senha-ou-app-password
SMTP_FROM="GeoópS <alertas@geoops.ia.br>"

# --- VIA 2: Resend (https://resend.com — plano gratuito; exige domínio verificado) ---
# RESEND_API_KEY=re_...
# RESEND_FROM="GeoópS <alertas@geoops.ia.br>"
